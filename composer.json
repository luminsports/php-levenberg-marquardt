{
  "name": "luminsports/levenberg-marquardt",
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Ryan Brereton",
      "email": "ryan@luminsports.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "LuminSports\\LevenbergMarquardt\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LuminSports\\LevenbergMarquardt\\Test\\": "tests"
    }
  },
  "require": {
    "php": "^8.1",
    "markbaker/matrix": "^2.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94.2",
    "phpstan/phpstan": "^2.1",
    "phpunit/php-code-coverage": "^10.1",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "test": "./vendor/bin/phpunit",
    "phpstan": "phpstan analyse",
    "check-style": "php-cs-fixer fix --dry-run",
    "fix-style": "php-cs-fixer fix"
  }
}
